{
  "manifest_version": 3,
  "name": "BrowserMemex",
  "version": "1.0.0",
  "description": "Connect AI coding agents, manage memory and skills, schedule recurring web tasks — all from your browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-memex@searchsim.org",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads",
    "identity",
    "nativeMessaging",
    "alarms",
    "bookmarks",
    "history",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "BrowserMemex",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "sidebar_action": {
    "default_panel": "dist/sidepanel.html",
    "default_title": "BrowserMemex",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "scripts": [
      "dist/service-worker.js"
    ],
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/accessibility-tree.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js",
        "src/content/agent-visual-indicator.js",
        "src/content/dom-tagging.js",
        "src/content/selection-toolbar.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}